#!/usr/bin/env bash
set -euo pipefail

# dev - Isolated parallel development environments
# Usage: dev <command> [options]

VERSION="0.13.0"

# ─── Debug mode ─────────────────────────────────────────────
# Set DEV_DEBUG=1 to enable trace output for troubleshooting.
if [ "${DEV_DEBUG:-}" = "1" ]; then
  set -x
fi

# ─── Resolve lib path ──────────────────────────────────────
# Support both installed (Homebrew) and development layouts:
#   Installed: bin/dev + lib/dev/*.sh (relative to bin/)
#   Dev:       bin/dev + lib/dev/*.sh (relative to repo root)
DEV_LIB_DIR=""
_self=$(realpath "$0" 2>/dev/null || readlink -f "$0" 2>/dev/null || echo "$0")
_bin_dir=$(dirname "$_self")

if [ -d "$_bin_dir/../lib/dev" ]; then
  DEV_LIB_DIR=$(cd "$_bin_dir/../lib/dev" && pwd)
else
  echo "ERROR: Cannot find lib/dev/ directory." >&2
  exit 1
fi
unset _self _bin_dir

source "$DEV_LIB_DIR/utils.sh"
source "$DEV_LIB_DIR/lifecycle.sh"
source "$DEV_LIB_DIR/session.sh"
source "$DEV_LIB_DIR/issue.sh"
source "$DEV_LIB_DIR/init.sh"
source "$DEV_LIB_DIR/doctor.sh"

# ─── Main ─────────────────────────────────────────────────────

usage() {
  cat <<EOF
dev $VERSION - Isolated parallel development environments

Usage: dev <command> [options]

Commands:
  init               Generate .devcontainer/ for this project
  up [name] [base]   Create (or resume) worktree + devcontainer
  code [name]        Start AI coding session
  shell [name]       Open a shell in devcontainer
  dash               Open tmux dashboard for all environments
  issue [number,...] Assign GitHub Issues to AI agents
  down [name]        Stop devcontainer (worktree kept)
  prune [name]       Remove worktree, containers, branch
  list               Show environments
  doctor             Check environment health

Run 'dev <command> --help' for details.

Environment variables:
  DEV_DEBUG=1           Enable debug trace output
  DEV_POLL_INTERVAL=N   Dashboard poll interval in seconds (default: 3)
EOF
}

# Dependency check (skip for help/version which don't need docker)
case "${1:-}" in
  -h|--help|""|--version|-v|doctor) ;;
  *)
    for _dep in docker git; do
      if ! command -v "$_dep" &>/dev/null; then
        echo "ERROR: '$_dep' is required but not found." >&2
        exit 1
      fi
    done
    unset _dep
    ;;
esac

case "${1:-}" in
  init)     shift; cmd_init "$@" ;;
  up)       shift; cmd_up "$@" ;;
  code)     shift; cmd_code "$@" ;;
  shell)    shift; cmd_shell "$@" ;;
  dash)     shift; cmd_dash "$@" ;;
  issue)    shift; cmd_issue "$@" ;;
  down)     shift; cmd_down "$@" ;;
  prune)    shift; cmd_prune "$@" ;;
  list|ls)  shift; cmd_list "$@" ;;
  doctor)   shift; cmd_doctor "$@" ;;
  _watcher)    shift; _watcher "$@" ;;
  _transcript) shift; _transcript "$@" ;;
  -v|--version) echo "dev $VERSION" ;;
  -h|--help|"") usage ;;
  *)      echo "Unknown command: $1" >&2; usage; exit 1 ;;
esac
